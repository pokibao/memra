<!-- EXAMPLE: Copy to com.memra.nightly-bench.plist and replace
     /YOUR/HOME with your home directory and /YOUR/PATH/TO with your project path.
     Install only on Pro-class lab hosts. -->
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.memra.nightly-bench</string>

    <key>ProgramArguments</key>
    <array>
        <string>/YOUR/PATH/TO/memra/scripts/nightly-bench.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/YOUR/PATH/TO/memra</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>4</integer>
        <key>Minute</key>
        <integer>45</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/YOUR/HOME/.memra/logs/nightly-bench-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/YOUR/HOME/.memra/logs/nightly-bench-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/YOUR/HOME/.local/bin</string>
        <key>HOME</key>
        <string>/YOUR/HOME</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
        <key>MA_SCORE_NORMALIZE</key>
        <string>z</string>
        <key>MA_BENCH_JUDGE_URL</key>
        <string>http://127.0.0.1:1234/v1/chat/completions</string>
        <key>MA_BENCH_JUDGE_MODEL</key>
        <string>gemma-4-e4b-it</string>
    </dict>
</dict>
</plist>
