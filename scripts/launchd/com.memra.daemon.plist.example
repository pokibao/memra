<!-- EXAMPLE: Copy to com.memra.daemon.plist and replace
     /YOUR/HOME with your home directory and /YOUR/PATH/TO with your project path.
     Install only on Pro-class lab hosts. -->
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.memra.daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>/YOUR/PATH/TO/memra/target/release/memra</string>
        <string>serve</string>
        <string>--daemon</string>
        <string>--project</string>
        <string>memra</string>
        <string>--socket</string>
        <string>/YOUR/HOME/.memra/run/memra.sock</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/YOUR/PATH/TO/memra</string>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/YOUR/HOME/.memra/logs/daemon-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/YOUR/HOME/.memra/logs/daemon-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/YOUR/HOME/.local/bin</string>
        <key>HOME</key>
        <string>/YOUR/HOME</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
        <key>MA_SCORE_NORMALIZE</key>
        <string>z</string>
    </dict>
</dict>
</plist>
