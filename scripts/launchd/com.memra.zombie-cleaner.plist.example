<!-- EXAMPLE: Copy to com.memra.zombie-cleaner.plist and replace
     /YOUR/HOME with your home directory and /YOUR/PATH/TO with your project path.
     Then: cp this.plist.example ~/Library/LaunchAgents/com.memra.zombie-cleaner.plist -->
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.memra.zombie-cleaner</string>

    <key>ProgramArguments</key>
    <array>
        <string>/YOUR/PATH/TO/memra/scripts/zombie-cleaner.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/YOUR/PATH/TO/memra</string>

    <!-- Every 15 minutes, terminate MA serve processes older than 1 hour. -->
    <key>StartInterval</key>
    <integer>900</integer>

    <key>StandardOutPath</key>
    <string>/YOUR/HOME/.memra/logs/zombie-cleaner-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/YOUR/HOME/.memra/logs/zombie-cleaner-stderr.log</string>

    <key>AbandonProcessGroup</key>
    <false/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/YOUR/HOME/.local/bin</string>
        <key>HOME</key>
        <string>/YOUR/HOME</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
        <key>MA_ZOMBIE_MAX_AGE_SECONDS</key>
        <string>3600</string>
    </dict>
</dict>
</plist>
