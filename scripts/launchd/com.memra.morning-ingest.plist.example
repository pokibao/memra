<!-- EXAMPLE: Copy to com.memra.morning-ingest.plist and replace
     /YOUR/HOME with your home directory and /YOUR/PATH/TO with your project path.
     Then: cp this.plist.example ~/Library/LaunchAgents/com.memra.morning-ingest.plist -->
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.memra.morning-ingest</string>

    <key>ProgramArguments</key>
    <array>
        <string>/YOUR/PATH/TO/memra/target/release/memra</string>
        <string>ingest</string>
        <string>--project</string>
        <string>memra</string>
        <string>--config</string>
        <string>/YOUR/HOME/.memra/ingest-roots.yaml</string>
        <string>--json</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/YOUR/PATH/TO/memra</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/YOUR/HOME/.memra/logs/morning-ingest-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/YOUR/HOME/.memra/logs/morning-ingest-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/YOUR/HOME/.local/bin</string>
        <key>HOME</key>
        <string>/YOUR/HOME</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
    </dict>
</dict>
</plist>
